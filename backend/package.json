{
  "name": "qlinexa360-backend",
  "version": "1.0.0",
  "description": "Backend API for Qlinexa360 medical platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "dev:clean": "powershell -Command \"Get-NetTCPConnection -LocalPort 3000 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force }; npm run dev\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "security:check": "npm audit --audit-level=moderate",
    "backup": "node scripts/backup.js",
    "backup:schedule": "node -e \"setInterval(() => require('./scripts/backup.js').runFullBackup(), 24 * 60 * 60 * 1000)\"",
    "logs:clean": "node -e \"require('fs').rmSync('./logs', { recursive: true, force: true }); console.log('Logs cleaned')\"",
    "security:scan": "npm audit && npm ls --depth=0",
    "test:upload": "node scripts/test-upload.js",
    "test:security": "npm run test:upload",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "ts-node prisma/seed.ts",
    "db:seed:forms": "node scripts/seed-form-templates-only.js",
    "db:studio": "prisma studio",
    "test:calendar": "ts-node scripts/test-calendar-sync.ts",
    "create:admin": "node scripts/createAdmin.js",
    "delete:patient": "ts-node scripts/deletePatientByEmail.ts",
    "check:preconsultation": "ts-node scripts/checkPreConsultation.ts",
    "check:patient": "ts-node scripts/checkPatientAppointments.ts",
    "diagnose:calendar": "ts-node scripts/diagnose-calendar-sync.ts",
    "find:calendar-ids": "ts-node scripts/find-calendar-ids.ts",
    "validate:prod": "ts-node scripts/validate-prod-data.ts",
    "migrate:dev-to-prod": "ts-node scripts/migrate-dev-to-prod.ts"
  },
  "keywords": [
    "medical",
    "healthcare",
    "api",
    "typescript",
    "nodejs",
    "prisma",
    "postgresql"
  ],
  "author": "Medilink360 Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.450.0",
    "@aws-sdk/s3-request-presigner": "^3.450.0",
    "@azure/msal-node": "^3.6.3",
    "@notionhq/client": "^5.4.0",
    "@prisma/client": "^5.6.0",
    "prisma": "^5.6.0",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "google-auth-library": "^10.5.0",
    "googleapis": "^153.0.0",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "node-ical": "^0.22.1",
    "nodemailer": "^6.9.7",
    "puppeteer": "^24.16.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "tsdav": "^2.1.6",
    "uuid": "^9.0.1",
    "axios": "^1.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.9.0",
    "@types/nodemailer": "^6.4.14",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "form-data": "^4.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/medilink360/backend.git"
  },
  "bugs": {
    "url": "https://github.com/medilink360/backend/issues"
  },
  "homepage": "https://github.com/medilink360/backend#readme"
}
