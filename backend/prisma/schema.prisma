/// Perfil de afiliado comercial (comisionista). Vinculado 1:1 a un User con rol AFFILIATE.
model AffiliateProfile {
  id                          String                 @id @default(uuid())
  userId                      String                 @unique
  affiliateCode               String                 @unique
  fullName                    String
  email                       String
  phone                       String?
  country                     String?
  status                      AffiliateStatus        @default(ACTIVE)
  defaultCommissionPercentage Decimal                @default(30) @db.Decimal(5, 2)
  defaultCommissionMonths     Int                    @default(6)
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt
  user                        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccounts                AffiliateBankAccount[]
  referrals                   AffiliateReferral[]
  commissions                 AffiliateCommission[]
  assignedCode                AffiliateCode?

  @@index([status])
  @@map("affiliate_profiles")
}

/// Datos bancarios del afiliado (MX: CLABE 18 dígitos; LATAM: cuenta + moneda).
model AffiliateBankAccount {
  id                     String           @id @default(uuid())
  affiliateId            String
  payoutMethod           String           @default("SPEI") // SPEI (México) | PAYPAL
  paypalEmail            String?
  beneficiaryFullName    String
  country                String
  bankName               String?
  clabe                  String?
  accountNumber          String?
  swiftBic               String?
  iban                   String?
  localBankCode          String?
  bankAddress            String?
  beneficiaryAddress     String?
  preferredCurrency      String
  additionalInstructions String?
  isActive               Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  affiliate              AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@map("affiliate_bank_accounts")
}

/// Doctor referido por un afiliado mediante su código. Único por doctor (1 afiliado por doctor).
model AffiliateReferral {
  id                String                  @id @default(uuid())
  affiliateId       String
  doctorUserId      String                  @unique
  doctorEmail       String
  doctorName        String?
