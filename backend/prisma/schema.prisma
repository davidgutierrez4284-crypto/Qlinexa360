  minPayoutAmountMxn   Decimal  @default(200) @db.Decimal(12, 2)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([isActive])
  @@map("affiliate_commission_rules")
}

/// Comisión generada por un pago exitoso de PayPal. Anti-duplicado por paypalPaymentId.
model AffiliateCommission {
  id                    String                    @id @default(uuid())
  affiliateId           String
  doctorUserId          String
  affiliateReferralId   String
  paypalPaymentId       String                    @unique
  paypalSubscriptionId  String?
  paymentDate           DateTime
  commissionMonthNumber Int
  paymentAmountGross    Decimal                   @db.Decimal(12, 2)
  vatRate               Decimal                   @db.Decimal(5, 4)
  paymentAmountNet      Decimal                   @db.Decimal(12, 2)
  commissionPercentage  Decimal                   @db.Decimal(5, 2)
  commissionAmount      Decimal                   @db.Decimal(12, 2)
  currency              String                    @default("MXN")
  status                AffiliateCommissionStatus @default(PENDING)
  calculationTraceJson  Json?
  payoutBatchId         String?
  payoutItemId          String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  paidAt                DateTime?
  paidByAdminUserId     String?
  affiliate             AffiliateProfile          @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
