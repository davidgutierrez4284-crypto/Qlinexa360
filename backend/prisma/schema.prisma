  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  affiliate         AffiliateProfile        @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  commissions       AffiliateCommission[]

  @@index([affiliateId])
  @@index([status])
  @@map("affiliate_referrals")
}

