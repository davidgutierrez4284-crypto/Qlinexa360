  amount                       Decimal  @default(0) @db.Decimal(12, 2)
  currency                     String   @default("MXN")
  refundPolicyText             String?  @db.Text
  autoCancelOnPaymentRejected  Boolean  @default(false)
  inPersonEnabled              Boolean  @default(false)
  inPersonDefaultAmount        Decimal  @default(0) @db.Decimal(12, 2)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  doctor                       Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("doctor_mercadopago_settings")
}

model PlatformMercadoPagoCommissionRule {
  id                                      String   @id @default(uuid())
  name                                    String   @default("Default")
  commissionPercentage                    Decimal  @default(1) @db.Decimal(5, 2)
  commissionFixedAmount                   Decimal  @default(0) @db.Decimal(12, 2)
  minCommissionAmount                     Decimal  @default(0) @db.Decimal(12, 2)
  maxCommissionAmount                     Decimal? @db.Decimal(12, 2)
  applyCommissionToTeleconsultation       Boolean  @default(true)
  applyCommissionToInPersonConsultation   Boolean  @default(true)
  isActive                                Boolean  @default(true)
  createdAt                               DateTime @default(now())
  updatedAt                               DateTime @updatedAt

  @@map("platform_mercadopago_commission_rules")
}

