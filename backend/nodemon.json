{
  "watch": ["src"],
  "ext": "ts,js,json",
  "ignore": ["src/**/*.spec.ts", "src/**/*.test.ts", "node_modules"],
  "exec": "ts-node src/server.ts",
  "env": {
    "NODE_ENV": "development"
  },
  "delay": "1000",
  "restartable": "rs",
  "verbose": true,
  "colours": true,
  "signal": "SIGTERM",
  "exitcrash": true,
  "crashDelay": 5000,
  "maxRestarts": 10,
  "legacyWatch": false
}
