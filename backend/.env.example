# Servidor
PORT=3000
NODE_ENV=development

# Desarrollo: saltar 2FA para usuarios con email inexistente (NUNCA en producciÃ³n)
# DISABLE_2FA_DEV=true

# Base de datos
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/medilink360"

# Seed demo de referidos (npm run seed:referral-demo): solo desarrollo/pruebas.
# - Con NODE_ENV=production el script aborta siempre.
# - Si NODE_ENV no es development|test, o DATABASE_URL no es local, define en entornos de QA:
#   ALLOW_REFERRAL_SEED_DEMO=true

# JWT
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRES_IN="24h"

# AWS (desarrollo: usar bucket distinto a prod para no afectar archivos reales)
# Ver docs/CONFIGURAR_BUCKET_DEV.md para crear qlinexa360-dev
# Smart Lab en NODE_ENV=development guarda PDFs en backend/uploads/ (no llama a S3).
# En producción sigue usando S3; se requieren keys válidas (InvalidAccessKeyId = key borrada/incorrecta).
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-2"
AWS_BUCKET_NAME="qlinexa360-dev"
AWS_S3_BUCKET_NAME="qlinexa360-dev"

# PayPal
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
# sandbox | live (por defecto sandbox)
PAYPAL_ENVIRONMENT="sandbox"
PAYPAL_WEBHOOK_ID="your-paypal-webhook-id"
# Pagos automÃ¡ticos a afiliados vÃ­a PayPal Payouts (true para habilitar).
# En producciÃ³n requiere que PayPal habilite la capacidad Payouts en la cuenta Business.
PAYPAL_PAYOUTS_ENABLED="false"

# Email (Zoho Mail con dominio propio: smtppro.zoho.com, puerto 465, SMTP_SECURE=true)
SMTP_HOST="smtppro.zoho.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="no-reply@tudominio.com"
SMTP_PASS="your-app-specific-password"
SMTP_FROM_NOREPLY="no-reply@tudominio.com"

# WhatsApp
WHATSAPP_API_KEY="your-whatsapp-api-key"
WHATSAPP_PHONE_NUMBER="+1234567890"

# Google Calendar OAuth (cada profesional vincula su propio calendario)
GOOGLE_CLIENT_ID="xxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxx"
# Local: http://localhost:3000/api/calendar-sync/auth/google/callback
# ProducciÃ³n: https://api.qlinexa360.com/api/calendar-sync/auth/google/callback
GOOGLE_REDIRECT_URI="https://api.qlinexa360.com/api/calendar-sync/auth/google/callback"

# URL del frontend (para redirigir tras OAuth)
FRONTEND_URL="https://www.qlinexa360.com"
# URL HTTPS para evidencia de auditorÃ­a (HU-01); si vacÃ­o se usa FRONTEND_URL
# AUDIT_EVIDENCE_HTTPS_URL="https://www.qlinexa360.com"

# === PRODUCCIÃ“N (ECS/Secrets Manager) - No usar valores reales aquÃ­ ===
# En PROD estas variables se inyectan via ECS task definition:
# - NODE_ENV=production
# - PORT=3000
# - AWS_REGION, AWS_BUCKET_NAME, AWS_S3_BUCKET_NAME
# - FRONTEND_URL=https://www.qlinexa360.com
# - BASE_URL=https://api.qlinexa360.com
# - JWT_EXPIRES_IN=24h
# - PAYPAL_ENVIRONMENT=live
# - SMTP_HOST, SMTP_PORT, SMTP_SECURE, SMTP_FROM_NOREPLY
# Secretos (Secrets Manager): DATABASE_URL, JWT_SECRET, PAYPAL_CLIENT_ID,
# PAYPAL_CLIENT_SECRET, SMTP_USER, SMTP_PASS
# Laboratorio Inteligente (runtime ECS, no secret): SMART_LAB_ENABLED=true

# Mercado Pago (cobros consulta paciente -> doctor, marketplace)
MERCADOPAGO_CLIENT_ID=""
MERCADOPAGO_CLIENT_SECRET=""
MERCADOPAGO_REDIRECT_URI="http://localhost:3000/api/payments/mercadopago/callback"
# Desarrollo OAuth: MP no acepta localhost; usar tÃºnel HTTPS (ver docs/MERCADOPAGO-DEV-TUNNEL.md):
# MERCADOPAGO_REDIRECT_URI="https://TU-ID.ngrok-free.app/api/payments/mercadopago/callback"
# BASE_URL="https://TU-ID.ngrok-free.app"
# FRONTEND_URL="http://localhost:5173"
MERCADOPAGO_WEBHOOK_SECRET=""
MERCADOPAGO_PLATFORM_ACCESS_TOKEN=""
MERCADOPAGO_AUTH_BASE_URL="https://auth.mercadopago.com.mx"
MERCADOPAGO_ENV="sandbox"
QLINEXA360_MARKETPLACE_FEE_PERCENTAGE="1"

# Laboratorio Inteligente (Smart Lab)
# En development el backend asume SMART_LAB_ENABLED=true si omitís el flag.
# En producción (ECS) debe ir explícito. Pacientes pueden subir PDF por defecto.
SMART_LAB_ENABLED="true"
SMART_LAB_MAX_PDF_MB="15"
SMART_LAB_PATIENT_UPLOAD_ENABLED="true"
SMART_LAB_EXTERNAL_OCR_ENABLED="false"
SMART_LAB_MISSING_FOLLOWUP_MONTHS="6"
SMART_LAB_REVIEW_THRESHOLD="0.9"
# Opcional: fallback OpenAI cuando el parser no alcanza confianza (requiere OPENAI_API_KEY)
SMART_LAB_AI_FALLBACK_ENABLED="false"
# SMART_LAB_OPENAI_MODEL="gpt-4o-mini"
