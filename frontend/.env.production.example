# Variables para build de produccion
# Copia a .env.production o configura antes de npm run build
# Vite las lee en tiempo de build

VITE_API_URL=https://api.qlinexa360.com
VITE_PAYPAL_CLIENT_ID=<tu-paypal-client-id-live>
# Caso A — sin promo, sin referido: trial 15d (gracia plataforma) + REGULAR
VITE_PAYPAL_PLAN_ID=<tu-plan-id>
# Reanudar cobros sin promo (doctor ya enrolado): plan sin trial. Si no se define, se usa VITE_PAYPAL_PLAN_ID.
VITE_PAYPAL_PLAN_RESUME=<plan-id-sin-trial-reanudacion>
# Planes con trial para códigos promocionales (crear en PayPal Dashboard)
# Mapeo escenarios (días trial / referido / gracia 15d): ver backend/docs/paypal-planes-mapeo.md
# C1/D1 alta: trial 45d (15 gracia + 30 promo). Reanudar con mismo promo: trial 30d en PayPal (alinear con renew en BD).
VITE_PAYPAL_PLAN_ID_TRIAL_1M=<plan-id-trial-1m-45d-alta>
VITE_PAYPAL_PLAN_ID_TRIAL_1M_RESUME=<plan-id-trial-1m-30d-reanudacion>
# E1 alta: trial 105d (15 gracia + 90). Reanudar con DISCOUNT_50_3M: trial 90d en PayPal.
VITE_PAYPAL_PLAN_ID_TRIAL_3M=<plan-id-trial-3m-105d-alta>
VITE_PAYPAL_PLAN_ID_TRIAL_3M_RESUME=<plan-id-trial-3m-90d-reanudacion>
# Misma matriz de días que la BD, con código de colega validado (trial en PayPal = gracia 15 + promo + 30 ref)
# Si no las defines, el front usa el plan sin sufijo _REF correspondiente.
VITE_PAYPAL_PLAN_REF=<plan-id-sin-promo-con-referido-45d-trial>
VITE_PAYPAL_PLAN_ID_TRIAL_1M_REF=<plan-id-trial-1m-con-referido-75d>
# E2: DISCOUNT_50_3M + referido (trial 135d en BD; el plan PayPal debe coincidir en días)
VITE_PAYPAL_PLAN_ID_TRIAL_3M_REF=<plan-id-trial-3m-con-referido-135d>
VITE_GOOGLE_CLIENT_ID=<tu-google-client-id>
VITE_GOOGLE_REDIRECT_URI=https://api.qlinexa360.com/api/calendar-sync/auth/google/callback

# Referidos en producción: true para activar UI + enlaces + planes _REF (build debe incluir esta línea)
VITE_ENABLE_REFERRALS=true

# Laboratorio Inteligente: true para activar UI en producción (requiere SMART_LAB_ENABLED=true en backend)
VITE_SMART_LAB_ENABLED=true
